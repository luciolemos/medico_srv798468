<!DOCTYPE html>
<html lang="pt-br" data-theme="dark">
<head>
  <meta charset="utf-8">
  <title>{% block title %}{{ app_name ?? 'Clínica Médica' }}{% endblock %}</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{% block meta_description %}Clínica médica com atendimento humanizado e agendamento online.{% endblock %}">
  {% if canonical_url is defined and canonical_url %}
  <link rel="canonical" href="{{ canonical_url|e('html_attr') }}">
  <meta property="og:url" content="{{ canonical_url|e('html_attr') }}">
  {% endif %}
  {% if should_noindex ?? false %}
  <meta name="robots" content="noindex, nofollow">
  {% else %}
  <meta name="robots" content="index, follow">
  {% endif %}
  <meta name="theme-color" content="#0b0f19">
  <script>
  (function () {
    const isValidTheme = (value) => value === "dark" || value === "light";
    const prefersLight = window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches;
    let theme = prefersLight ? "light" : "dark";
    try {
      const saved = localStorage.getItem("theme");
      if (isValidTheme(saved)) theme = saved;
    } catch (e) {}
    document.documentElement.setAttribute("data-theme", theme);
    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.setAttribute("content", theme === "dark" ? "#0b0f19" : "#f8fafc");
  })();
  </script>

  <link rel="icon" href="{{ base_url }}/assets/img/clinic-mark.svg">

  {# ==============================
     CSS — LIBS
     ============================== #}

  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="preconnect" href="https://unpkg.com">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Fonts: Sora (titles) + Space Grotesk (body) + JetBrains Mono (labels) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet"></noscript>

  <!-- Bootstrap Icons -->
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"></noscript>

  {# ==============================
     CSS — APP
     ============================== #}

  <link href="{{ base_url }}/assets/css/app.css?v={{ asset_version|default('1')|url_encode }}" rel="stylesheet">
  <link href="{{ base_url }}/assets/css/landing.css?v={{ asset_version|default('1')|url_encode }}" rel="stylesheet">
  <link
    href="{{ base_url }}/assets/css/palettes/{{ palette ?? app_palette ?? 'blue' }}.css?v={{ asset_version|default('1')|url_encode }}"
    rel="stylesheet"
    id="paletteStylesheet"
    data-palette-link
    data-palette-base="{{ base_url }}/assets/css/palettes"
    data-palette-version="{{ asset_version|default('1')|e('html_attr') }}"
    data-palette-default="{{ palette ?? app_palette ?? 'blue' }}"
      data-palette-allowed="{{ (allowed_palettes ?? ['blue', 'red', 'emerald', 'amber', 'violet'])|json_encode|e('html_attr') }}"
  >
   {% set warm_palettes = ['blue', 'red', 'emerald'] %}
   {% for warm_palette in warm_palettes %}
   {% if warm_palette != (palette ?? app_palette ?? 'blue') %}
   <link rel="prefetch" href="{{ base_url }}/assets/css/palettes/{{ warm_palette }}.css?v={{ asset_version|default('1')|url_encode }}" as="style">
   {% endif %}
   {% endfor %}

  {% block head_extra %}{% endblock %}
</head>


<body class="bg-body text-body antialiased">

<div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>

{# ==============================
   CONTEÚDO
   ============================== #}

{% block content %}{% endblock %}



{# ==============================
   SCRIPTS — LIBS
   ============================== #}

<!-- Bootstrap bundle -->
<script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{# ==============================
   CONFIG GLOBAL JS
   ============================== #}

<script>
window.APP = {
  baseUrl: "{{ base_url }}",
   env: "{{ app_env ?? 'prod' }}",
   allowedPalettes: {{ (allowed_palettes ?? ['blue', 'red', 'emerald', 'amber', 'violet'])|json_encode|raw }}
};
</script>


{# ==============================
   JS — APP CORE
   ============================== #}

<script defer src="{{ base_url }}/assets/js/landing.js?v={{ asset_version|default('1')|url_encode }}"></script>


{% block body_extra %}{% endblock %}

</body>
</html>

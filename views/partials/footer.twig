{% set footer_content = landing_content.footer|default({}) %}

<footer class="footer py-4 mt-5">
  <div class="container">
    <div class="row gy-3 align-items-center">
      <div class="col-12 col-md-7">
        <div class="small text-secondary-emphasis">
          <strong>{{ app_name ?? 'Landing de saúde' }} - {{ footer_content.label|default('Atendimento') }}</strong><br>
          © <span id="year">{{ "now"|date("Y") }}</span> — Todos os direitos reservados
        </div>

        <div class="small text-secondary-emphasis">
          {{ company_address ?? footer_content.address|default('Atendimento presencial com horário agendado') }}<br>
          {{ company_meta ?? footer_content.meta|default('Consultas, check-ups e acompanhamento clínico') }}
        </div>

        <div class="d-flex gap-3 mt-2">
          <a class="footer-link" href="{{ facebook_url ?? '#' }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <i class="bi bi-facebook"></i>
          </a>

          <a class="footer-link" href="{{ instagram_url ?? '#' }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <i class="bi bi-instagram"></i>
          </a>

          <a class="footer-link" href="{{ whatsapp_url ?? '#' }}" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <i class="bi bi-whatsapp"></i>
          </a>
        </div>

        <div class="small text-secondary  mt-2 mb-5">
          {{ footer_content.emergency_note|default('Atendimento eletivo. Em caso de urgência ou emergência, procure o pronto atendimento mais próximo.') }}
        </div>
      </div>

      {% if footer_content.credit|default('') %}
        <div class="col-12 col-md-5">
          <div class="footer-credit small text-md-end">
            {{ footer_content.credit }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</footer>

<button class="back-to-top btn btn-primary shadow" id="backToTop"
        aria-label="Voltar ao topo" title="Voltar ao topo">
  <i class="bi bi-chevron-up"></i>
</button>

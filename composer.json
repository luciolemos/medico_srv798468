{
  "name": "agency/medico",
  "description": "Landing page de clínica médica em Slim 4 e Twig.",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.3 || ^8.4",
    "ext-ctype": "*",
    "ext-filter": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "ext-session": "*",
    "twig/twig": "^3.0",
    "slim/slim": "^4.15",
    "slim/psr7": "^1.8",
    "slim/twig-view": "^3.4",
    "phpmailer/phpmailer": "^6.9"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  }
}
